{
  "name": "@z4phcode/z4ph.core",
  "version": "1.5.0",
  "description": "z4ph.core — Modified Baileys WhatsApp Web Engine · 2025",
  "keywords": [
    "whatsapp",
    "websocket",
    "api",
    "nodejs",
    "baileys",
    "wabot",
    "proto",
    "whatsapp-websocket"
  ],
  "homepage": "https://github.com/bianoffc/z4ph.core",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/bianoffc/z4ph.core.git"
  },
  "license": "MIT",
  "author": "bianoffc",
  "main": "./src/index.js",
  "files": [
    "src/*",
    "proto/*"
  ],
  "scripts": {
    "changelog:update": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
    "changelog:preview": "conventional-changelog -p angular -u",
    "changelog:last": "conventional-changelog -p angular -r 2",
    "gen:protobuf": "sh WAProto/GenerateStatics.sh",
    "example": "node --inspect Example/example.js",
    "lint": "eslint src --ext .js",
    "lint:fix": "yarn lint --fix",
    "release": "release-it",
    "test": "jest"
  },
  "dependencies": {
    "@whiskeysockets/eslint-config": "github:whiskeysockets/eslint-config",
    "@cacheable/node-cache": "*",
    "gradient-string": "2.0.2",
    "@z4phcode/libsignal": "*",
    "music-metadata": "*",
    "cache-manager": "*",
    "async-mutex": "*",
    "@hapi/boom": "*",
    "pbjs": "^0.0.14",
    "protobufjs": "*",
    "lru-cache": "*",
    "p-queue": "*",
    "lodash": "*",
    "figlet": "*",
    "axios": "*",
    "pino": "*",
    "ws": "*",
    "chalk": "*",
    "long": "*"
  },
  "devDependencies": {
    "conventional-changelog-cli": "*",
    "protobufjs-cli": "*",
    "cache-manager": "*",
    "@types/jest": "*",
    "@types/node": "*",
    "release-it": "*",
    "@types/ws": "*",
    "eslint": "*",
    "jest": "*",
    "json": "*",
    "open": "*",
    "link-preview-js": "*"
  },
  "peerDependencies": {
    "audio-decode": "*",
    "jimp": ">=0.16.0",
    "link-preview-js": "*"
  },
  "peerDependenciesMeta": {
    "audio-decode": {
      "optional": true
    },
    "chalk": {
      "optional": true
    },
    "jimp": {
      "optional": true
    },
    "link-preview-js": {
      "optional": true
    }
  },
  "packageManager": "yarn@1.22.19",
  "engines": {
    "node": ">=20.0.0"
  },
  "directories": {
    "lib": "lib"
  },
  "bugs": {
    "url": "https://github.com/bianoffc/z4ph.core/issues"
  }
}
